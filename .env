# ─── Database ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=iqac_portal
DB_USER=root
DB_PASSWORD=your_mysql_password

# ─── JWT ────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRES_IN=8h

# ─── Server ─────────────────────────────────────────
PORT=5000
CLIENT_ORIGIN=http://localhost:3000

# ─── File uploads ───────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
